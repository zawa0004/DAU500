{"cells":[{"cell_type":"code","source":["# =======================================================================\n","# 神经网络与Keras实战：加州房价预测\n","# =======================================================================\n","\n","# 导入核心库\n","import tensorflow as tf\n","from tensorflow import keras\n","\n","# 导入数据和预处理库\n","from sklearn.datasets import fetch_california_housing\n","from sklearn.model_selection import train_test_split\n","from sklearn.preprocessing import StandardScaler\n","\n","# 导入工具\n","import numpy as np\n","import pandas as pd\n","import matplotlib.pyplot as plt\n","import os\n","\n","# 设置随机种子\n","np.random.seed(42)\n","tf.random.set_seed(42)\n","print(\"设置随机种子完成。\")\n","\n","\n","# -----------------------------------------------------------------------\n","# 1. 加载加州房价数据集并进行划分\n","# -----------------------------------------------------------------------\n","\n","print(\"\\n--- 1. 加载和预处理数据 ---\")\n","# 加载数据集\n","housing = fetch_california_housing()\n","print(\"数据集加载完成。\")\n","\n","# 划分训练集和测试集\n","X_train_full, X_test, y_train_full, y_test = train_test_split(\n","    housing.data, housing.target, random_state=42)\n","print(f\"完整训练集形状: {X_train_full.shape}\")\n","\n","# 划分训练集和验证集\n","X_train, X_valid, y_train, y_valid = train_test_split(\n","    X_train_full, y_train_full, random_state=42)\n","print(f\"训练集形状: {X_train.shape}, 验证集形状: {X_valid.shape}, 测试集形状: {X_test.shape}\")\n","\n","\n","# 数据标准化\n","scaler = StandardScaler()\n","X_train_scaled = scaler.fit_transform(X_train)\n","X_valid_scaled = scaler.transform(X_valid)\n","X_test_scaled = scaler.transform(X_test)\n","print(\"数据标准化完成。\")\n","\n","\n","# -----------------------------------------------------------------------\n","# 2. 构建并训练一个基础神经网络模型\n","# -----------------------------------------------------------------------\n","\n","print(\"\\n--- 2. 构建和训练基础模型 ---\")\n","\n","# 创建顺序模型\n","model = keras.models.Sequential([\n","    keras.layers.InputLayer(input_shape=X_train_scaled.shape[1:]),\n","    keras.layers.Dense(30, activation=\"relu\"), # 隐藏层 1\n","    keras.layers.Dense(30, activation=\"relu\"), # 隐藏层 2\n","    keras.layers.Dense(1)                      # 输出层\n","])\n","\n","# 编译模型\n","model.compile(loss=\"mse\",              # 均方误差损失\n","              optimizer=\"sgd\",         # 随机梯度下降优化器\n","              metrics=[\"mae\"])         # 平均绝对误差指标\n","print(\"模型编译完成 (Optimizer: SGD, Loss: MSE)。\")\n","model.summary() # 打印模型结构概览\n","\n","# 训练模型\n","print(\"开始训练基础模型 (20 epochs)...\")\n","history = model.fit(X_train_scaled, y_train,\n","                    epochs=20,\n","                    validation_data=(X_valid_scaled, y_valid))\n","\n","print(\"\\n--- 基础模型训练结果 (MAE): ---\")\n","print(f\"最终验证集 MAE: {history.history['val_mae'][-1]:.4f}\")\n","\n","\n","# -----------------------------------------------------------------------\n","# 3. 绘制网络历史曲线\n","# -----------------------------------------------------------------------\n","\n","def plot_history(history):\n","    \"\"\"绘制训练过程中的损失(loss)和平均绝对误差(MAE)曲线\"\"\"\n","    pd.DataFrame(history.history).plot(figsize=(8, 5))\n","    plt.grid(True)\n","    plt.gca().set_ylim(0, 1.5)\n","    plt.title(\"Model traing:(Loss & MAE)\")\n","    plt.xlabel(\"Epochs\")\n","    plt.ylabel(\"Loss / MAE Value\")\n","    plt.show()\n","\n","print(\"\\n--- 3. 绘制网络历史曲线 ---\")\n","plot_history(history)\n","\n","# --- 结果讨论 ---\n","print(\"结果讨论 (基础模型):\")\n","print(\"通过观察曲线，如果验证集损失 (val_loss) 上升而训练集损失 (loss) 继续下降，则可能发生过拟合。\")\n","\n","\n","# -----------------------------------------------------------------------\n","# 4. 改变学习率 (Learning Rate) 并重新训练\n","# -----------------------------------------------------------------------\n","\n","print(\"\\n--- 4. 改变学习率并重新训练 ---\")\n","\n","# 重新构建模型\n","model_lr = keras.models.Sequential([\n","    keras.layers.InputLayer(input_shape=X_train_scaled.shape[1:]),\n","    keras.layers.Dense(30, activation=\"relu\"),\n","    keras.layers.Dense(30, activation=\"relu\"),\n","    keras.layers.Dense(1)\n","])\n","\n","# 创建低学习率优化器\n","new_lr = 0.0001\n","sgd_optimizer = keras.optimizers.SGD(learning_rate=new_lr)\n","print(f\"设置新的学习率为: {new_lr}\")\n","\n","# 编译模型\n","model_lr.compile(loss=\"mse\",\n","        optimizer=sgd_optimizer,\n","        metrics=[\"mae\"])\n","\n","# 训练模型 (40 epochs)\n","print(\"开始训练低学习率模型 (40 epochs)...\")\n","history_lr = model_lr.fit(X_train_scaled, y_train,\n","              epochs=40,\n","              validation_data=(X_valid_scaled, y_valid))\n","\n","print(f\"\\n--- 学习率为 {new_lr} 的模型训练结果: ---\")\n","print(f\"最终验证集 MAE: {history_lr.history['val_mae'][-1]:.4f}\")\n","\n","# 绘制新的历史曲线\n","plot_history(history_lr)\n","\n","# --- 结果讨论 (学习率变化) ---\n","print(\"结果讨论 (学习率变化):\")\n","print(f\"学习率从默认值 0.01 降至 {new_lr} 后，训练速度通常会变慢，但可能更稳定。\")\n","\n","\n","# -----------------------------------------------------------------------\n","# 5. 使用回调 (Callbacks) 进行训练，并保存最佳权重\n","# -----------------------------------------------------------------------\n","\n","print(\"\\n--- 5. 使用回调函数 (Callbacks) ---\")\n","\n","# 重新构建模型\n","model_cb = keras.models.Sequential([\n","    keras.layers.InputLayer(input_shape=X_train_scaled.shape[1:]),\n","    keras.layers.Dense(30, activation=\"relu\"),\n","    keras.layers.Dense(30, activation=\"relu\"),\n","    keras.layers.Dense(1)\n","])\n","model_cb.compile(loss=\"mse\", optimizer=\"sgd\", metrics=[\"mae\"])\n","\n","# 定义 ModelCheckpoint 回调，只保存最佳权重\n","# 更改文件扩展名以使用推荐的 Keras Native Format\n","checkpoint_cb = keras.callbacks.ModelCheckpoint(\"my_best_model.keras\", save_best_only=True)\n","print(\"定义 ModelCheckpoint (保存到 my_best_model.keras)。\")\n","\n","# 定义 EarlyStopping 回调，连续 10 次不改进则停止\n","early_stopping_cb = keras.callbacks.EarlyStopping(patience=10, restore_best_weights=True)\n","print(\"定义 EarlyStopping (patience=10)。\")\n","\n","# 训练模型，传入回调列表\n","print(\"开始训练模型 (使用 Callbacks)...\")\n","history_cb = model_cb.fit(X_train_scaled, y_train,\n","              epochs=30,\n","                validation_data=(X_valid_scaled, y_valid),\n","              callbacks=[checkpoint_cb, early_stopping_cb])\n","print(\"训练结束，模型已恢复为最佳权重。\")\n","\n","# 评估最佳模型\n","mse_test = model_cb.evaluate(X_test_scaled, y_test, verbose=0)\n","print(\"\\n--- 5. 回调函数训练结果 ---\")\n","print(f\"测试集评估 (使用最佳权重): MSE={mse_test[0]:.4f}, MAE={mse_test[1]:.4f}\")\n","\n","\n","# -----------------------------------------------------------------------\n","# 6. 保存和加载训练好的模型\n","# -----------------------------------------------------------------------\n","\n","print(\"\\n--- 6. 保存和加载模型 ---\")\n","\n","# 定义保存路径，更改文件扩展名以使用推荐的 Keras Native Format\n","model_save_path = \"my_california_housing_model.keras\"\n","\n","# 保存整个模型\n","model_cb.save(model_save_path)\n","print(f\"✅ 模型已完整保存到: {model_save_path}\")\n","\n","# 加载模型\n","loaded_model = keras.models.load_model(model_save_path)\n","print(\"✅ 模型已成功加载。\")\n","\n","# 评估加载的模型\n","loaded_model_mse = loaded_model.evaluate(X_test_scaled, y_test, verbose=0)\n","\n","print(\"\\n--- 模型加载验证结果 ---\")\n","print(f\"原始模型测试集 MAE: {mse_test[1]:.4f}\")\n","print(f\"加载模型测试集 MAE: {loaded_model_mse[1]:.4f}\")\n","\n","# 使用加载的模型进行预测\n","X_new = X_test_scaled[:3]\n","y_pred = loaded_model.predict(X_new)\n","\n","print(\"\\n--- 预测结果示例 (前 3 个样本) ---\")\n","print(\"输入数据形状:\", X_new.shape)\n","print(\"原始价格 (百万美元):\", y_test[:3])\n","print(\"预测价格 (百万美元):\")\n","for i, price in enumerate(y_pred):\n","    print(f\"  样本 {i+1}: {price[0]:.4f}\")\n","\n","\n","# -----------------------------------------------------------------------\n","# 7. 进一步模型优化 (自定义层, 子类化, 广度和深度网络)\n","# -----------------------------------------------------------------------\n","\n","print(\"\\n--- 7. 进一步模型优化 ---\")\n","\n","# 7.1 自定义激活函数\n","print(\"\\n--- 7.1 自定义激活函数 ---\")\n","\n","def my_softplus(z):\n","    return tf.math.log(tf.exp(z) + 1.0)\n","\n","# 7.2 自定义初始化器\n","print(\"\\n--- 7.2 自定义初始化器 ---\")\n","\n","def glorot_initializer(shape, dtype=tf.float32):\n","    stddev = tf.sqrt(2. / (shape[0] + shape[1]))\n","    return tf.random.normal(shape, stddev=stddev, dtype=dtype)\n","\n","# 7.3 自定义正则化器 (L1 正则化)\n","print(\"\\n--- 7.3 自定义正则化器 (L1 正则化) ---\")\n","\n","keras.regularizers.l1(0.01)\n","\n","# 7.4 自定义层 (例如, 没有偏置项的密集层)\n","print(\"\\n--- 7.4 自定义层 ---\")\n","\n","class NoBiasDense(keras.layers.Layer):\n","    def __init__(self, units, activation=None, **kwargs):\n","        super().__init__(**kwargs)\n","        self.units = units\n","        self.activation = keras.activations.get(activation)\n","\n","    def build(self, input_shape):\n","        self.kernel = self.add_weight(\n","            name='kernel', shape=(input_shape[-1], self.units),\n","            initializer='glorot_normal')\n","        super().build(input_shape)\n","\n","    def call(self, inputs):\n","        return self.activation(inputs @ self.kernel)\n","\n","    def get_config(self):\n","        config = super().get_config()\n","        config.update({\n","            'units': self.units,\n","            'activation': keras.activations.serialize(self.activation)\n","        })\n","        return config\n","\n","print(\"自定义层 'NoBiasDense' 已定义。\")\n","\n","# 7.5 构建一个广度深度网络\n","print(\"\\n--- 7.5 构建广度深度网络 ---\")\n","\n","# 定义输入层\n","input_wide = keras.layers.Input(shape=[5])  # 广度路径的输入特征\n","input_deep = keras.layers.Input(shape=[6])  # 深度路径的输入特征 (这里假设分开)\n","\n","# 深度路径\n","hidden1 = keras.layers.Dense(30, activation=\"relu\")(input_deep)\n","hidden2 = keras.layers.Dense(30, activation=\"relu\")(hidden1)\n","\n","# 将广度路径和深度路径连接起来\n","concat = keras.layers.concatenate([input_wide, hidden2])\n","\n","# 输出层\n","output = keras.layers.Dense(1)(concat)\n","\n","# 创建模型\n","wide_and_deep_model = keras.models.Model(inputs=[input_wide, input_deep], outputs=[output])\n","\n","# 编译模型\n","wide_and_deep_model.compile(loss=\"mse\", optimizer=\"sgd\")\n","print(\"广度深度模型已构建并编译。\")\n","wide_and_deep_model.summary()\n","\n","\n","# 准备广度深度网络的数据 (示例)\n","# 注意：这里为了演示，简单地将 X_train_scaled 拆分，实际应用中应根据特征选择。\n","X_train_wide, X_train_deep = X_train_scaled[:, :5], X_train_scaled[:, 2:]\n","X_valid_wide, X_valid_deep = X_valid_scaled[:, :5], X_valid_scaled[:, 2:]\n","X_test_wide, X_test_deep = X_test_scaled[:, :5], X_test_scaled[:, 2:]\n","\n","print(\"开始训练广度深度模型 (10 epochs)...\")\n","history_wide_deep = wide_and_deep_model.fit(\n","    (X_train_wide, X_train_deep), y_train,\n","    epochs=10,\n","    validation_data=((X_valid_wide, X_valid_deep), y_valid)\n",")\n","print(\"广度深度模型训练完成。\")\n","\n","# 7.6 具有多个输出的广度深度网络\n","print(\"\\n--- 7.6 具有多个输出的广度深度网络 ---\")\n","\n","# 定义输入\n","input_multi_wide = keras.layers.Input(shape=[5])\n","input_multi_deep = keras.layers.Input(shape=[6])\n","\n","# 深度路径\n","hidden1_multi = keras.layers.Dense(30, activation=\"relu\")(input_multi_deep)\n","hidden2_multi = keras.layers.Dense(30, activation=\"relu\")(hidden1_multi)\n","\n","# 连接\n","concat_multi = keras.layers.concatenate([input_multi_wide, hidden2_multi])\n","\n","# 主输出 (例如，预测房价)\n","output_main = keras.layers.Dense(1, name=\"main_output\")(concat_multi)\n","\n","# 辅助输出 (例如，对部分输入进行正则化或预测相关属性)\n","output_aux = keras.layers.Dense(1, name=\"aux_output\")(hidden2_multi) # 辅助输出直接连接到深度路径的第二层\n","\n","# 创建多输出模型\n","multi_output_model = keras.models.Model(\n","    inputs=[input_multi_wide, input_multi_deep],\n","    outputs=[output_main, output_aux]\n",")\n","\n","# 编译模型，为每个输出指定损失和损失权重\n","multi_output_model.compile(\n","    loss=[\"mse\", \"mse\"],\n","    loss_weights=[0.9, 0.1], # 主输出权重更高\n","    optimizer=\"sgd\"\n",")\n","print(\"多输出模型已构建并编译。\")\n","multi_output_model.summary()\n","\n","# 准备多输出网络的数据 (示例)\n","# 辅助输出的真实值可能与主输出相同，或者来自不同的标签\n","y_train_aux = y_train # 示例：辅助输出和主输出预测相同目标\n","y_valid_aux = y_valid\n","\n","print(\"开始训练多输出模型 (10 epochs)...\")\n","history_multi_output = multi_output_model.fit(\n","    (X_train_wide, X_train_deep), (y_train, y_train_aux),\n","    epochs=10,\n","    validation_data=((X_valid_wide, X_valid_deep), (y_valid, y_valid_aux))\n",")\n","print(\"多输出模型训练完成。\")"],"outputs":[{"output_type":"stream","name":